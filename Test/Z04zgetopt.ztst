>-- a b c
>-a --
>-a -- a b c
>-a -b c -- a
>-a -b -c -- a
>-a -b -c -- a d
>-a -b -c -c '' -- a
>-a -b -c -c '' -- a d
>-a -b -c -c d -- a

  zgetopt -A '' -l aaa,bbb:,ccc:: -- a b c
  zgetopt -A '' -l aaa,bbb:,ccc:: -- --aaa
  zgetopt -A '' -l aaa,bbb:,ccc:: -- --aaa a b c
  zgetopt -A '' -l aaa,bbb:,ccc:: -- --aaa a --bbb c
