>-- a b c
>-- a b c

  zgetopt -A '' -l a,+ -- a b c
  zgetopt -A '' -l a,= -- a b c
  zgetopt -A '' -l a,\\ -- a b c
  zgetopt -A '' -l a,: -- a b c
  zgetopt -A '' -l a,:b -- a b c
  zgetopt -A '' -l a,b:b -- a b c
  zgetopt -A '' -l a,b::: -- a b c
  zgetopt -A '' -l '' -- a b c
  zgetopt -A '' -l , -- a b c
  zgetopt -A '' -l a,,,,,b -- a b c
  zgetopt -A '' -l - -- a b c ---
