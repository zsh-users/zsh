%prep

  autoload -Uz zgetopt

%test

  zgetopt -A '' -- a b c
  zgetopt -A '' -o '' -- a b c
  zgetopt -A '' -l '' -- a b c
0:-o or -l required
?(eval):zgetopt: missing option spec
>-- a b c
>-- a b c

  zgetopt -A '' -o - -- a b c
  zgetopt -A '' -o -a -- a b c
  zgetopt -A '' -o a- -- a b c
  zgetopt -A '' -o a+ -- a b c
  zgetopt -A '' -o a= -- a b c
  zgetopt -A '' -o a\\ -- a b c
  zgetopt -A '' -o :a -- a b c
  zgetopt -A '' -o a::: -- a b c
  zgetopt -A '' -o '' -- a b c
  zgetopt -A '' -o + -- a b c
