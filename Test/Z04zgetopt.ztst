  zgetopt -n aaa -A '' -o a: -- -x
  zgetopt -n aaa -A '' -o a: -- -a
  ()     { zgetopt -n bbb -A '' -o a: -- "$@"; : } -x
  func() { zgetopt -n ccc -A '' -o a: -- "$@"; : }; func -x
  f1()   { zgetopt -n ddd -A '' -o a: -- "$@"; : }; f2() { f1 "$@" }; f2 -x
