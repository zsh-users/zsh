>-- a b c
>-- a b c
>-- a b c
>--- -- a b c

  zgetopt -A '' -o ab:c:: -- a b c
  zgetopt -A '' -o ab:c:: -- -a
  zgetopt -A '' -o ab:c:: -- -a a b c
  zgetopt -A '' -o ab:c:: -- -a a -b c
  zgetopt -A '' -o ab:c:: -- -a a -b -c
  zgetopt -A '' -o ab:c:: -- -a a -b -c d
  zgetopt -A '' -o ab:c:: -- -a a -b -c -c
  zgetopt -A '' -o ab:c:: -- -a a -b -c -c d
  zgetopt -A '' -o ab:c:: -- -a a -b -c -cd
