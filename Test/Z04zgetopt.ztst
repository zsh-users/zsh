?(eval):zgetopt: invalid long-option spec: +
?(eval):zgetopt: invalid long-option spec: =
?(eval):zgetopt: invalid long-option spec: \
?(eval):zgetopt: invalid long-option spec: :
?(eval):zgetopt: invalid long-option spec: :b
?(eval):zgetopt: invalid long-option spec: b:b
