     () {
       local var=l3
       ref1=var
       echo B1: ref1=$ref1 ref2=$ref2
     }
     ref2=var
     # At this point, "ref1" and "ref2" refer to the same undefined
     # variable "var". Going forward, they should behave the same.
     echo B2: ref1=$ref1 ref2=$ref2
