  # not enough arguments
  () { getopts }
  () { getopts '' }
  () { getopts x }
  () { getopts - x }
  () { getopts -p - x }
  () { getopts -p -- x }
  # invalid option to getopts
  () { getopts -x x }
  () { getopts -x x y }
  () { getopts -x - x y }
  # guarded spec
  () { getopts - -x y }
  # argv on command line
  () { getopts x y a b c }
