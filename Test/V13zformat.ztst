  for 1 in - . 0 9; do
    REPLY1= REPLY2=
    zformat -F REPLY1 %$1
    zformat -F REPLY2 %1$1
    zformat -F REPLY3 %1%$1
    print -r - $REPLY1 $REPLY2 $REPLY3
  done
