>123456 ^[[38;5;24m
>654321 ^[[38;5;95m
>87af5f ^[[38;5;107m
>8a6cb4 ^[[38;5;97m
>a5e02d ^[[38;5;148m
>cccccc ^[[38;5;252m
>d0d0d0 ^[[38;5;252m
