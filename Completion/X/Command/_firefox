# options support both single and double hyphens. recognise the alternate forms
for x in $tmp; do
  args+=( $x )
  [[ $x == (#b)(|\(*\))(|\*)(--|-)([^-]*) ]] && {
    [[ $match[3] == - ]] && match[3]=-- || match[3]=-
    args+=( \!${(j<>)match} )
  }
done

# options are also case-insensitive
_arguments -s -S -M 'm:{A-Za-z}={a-zA-Z} r:|[_-]=* r:|=*' : $args
